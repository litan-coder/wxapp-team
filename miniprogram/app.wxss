/* 全局样式变量 */
page {
  --primary: #4f6ef7;
  --primary-light: #6b85f9;
  --danger: #e74c3c;
  --success: #27ae60;
  --bg: #f0f2f5;
  --card-bg: #ffffff;
  --text: #333333;
  --text-light: #888888;
  --border: #e8e8e8;
  --radius: 16rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: var(--text);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  width: 100%;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: #ffffff;
}

.btn-primary:active {
  background: var(--primary-light);
}

.btn-danger {
  background: var(--danger);
  color: #ffffff;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: var(--text);
}

.form-input-focus {
  border-color: var(--primary);
}

textarea.form-input {
  height: 160rpx;
  padding: 20rpx 24rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-male {
  background: #e8f0fe;
  color: #1a73e8;
}

.tag-female {
  background: #fce8f0;
  color: #d04580;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-light);
  font-size: 28rpx;
}
