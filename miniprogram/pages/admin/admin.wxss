.container {
  padding-bottom: 32rpx;
}

/* 顶部栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #4f6ef7;
  color: #ffffff;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

.header-user {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

.logout-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border-radius: 8rpx;
  line-height: 1.4;
  min-height: auto;
}

.logout-btn::after {
  border: none;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333333;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title-row .card-title {
  margin-bottom: 0;
}

.btn-export {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  background: #f0f4ff;
  color: #4f6ef7;
  border-radius: 8rpx;
  line-height: 1.4;
  min-height: auto;
  border: 2rpx solid #4f6ef7;
}

.btn-export::after {
  border: none;
}

/* 统计网格 */
.stats-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #4f6ef7;
  margin-bottom: 8rpx;
}

.stat-value.male {
  color: #1a73e8;
}

.stat-value.female {
  color: #d04580;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
}

/* 统计分区 */
.stat-section {
  margin-bottom: 24rpx;
}

.stat-section:last-child {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 柱状图 */
.bar-chart {
  padding: 0 8rpx;
}

.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.bar-row:last-child {
  margin-bottom: 0;
}

.bar-label {
  width: 100rpx;
  font-size: 24rpx;
  color: #666666;
  text-align: right;
  margin-right: 16rpx;
}

.bar-track {
  flex: 1;
  height: 36rpx;
  background: #f0f2f5;
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #4f6ef7;
  border-radius: 6rpx;
  min-width: 4rpx;
  transition: width 0.4s;
}

.bar-value {
  width: 60rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
  text-align: right;
  margin-left: 12rpx;
}

/* 爱好标签 */
.hobby-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hobby-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  background: #f0f4ff;
  color: #4f6ef7;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.hobby-count {
  font-weight: 700;
  margin-left: 4rpx;
}

/* 记录列表 */
.entry-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.entry-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.entry-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.entry-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.entry-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 8rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666666;
}

.entry-remark {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 8rpx;
  padding: 12rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.entry-time {
  font-size: 24rpx;
  color: #aaaaaa;
  margin-bottom: 16rpx;
}

.entry-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  line-height: 1.4;
  min-height: auto;
}

.action-btn::after {
  border: none;
}

.delete-btn {
  background: #fce8e8;
  color: #e74c3c;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #888888;
  font-size: 28rpx;
}