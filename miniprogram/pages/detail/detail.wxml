<view class="container" wx:if="{{entry}}" catchtouchstart="onSwipeStart" catchtouchmove="onSwipeMove" catchtouchend="onSwipeEnd">
  <!-- 头像区 -->
  <view class="hero-card">
    <view class="avatar {{entry.gender === '男' ? 'avatar-male' : 'avatar-female'}}">
      {{entry.gender === '男' ? '♂' : '♀'}}
    </view>
    <text class="hero-name">{{entry.name}}</text>
    <view class="hero-tags">
      <text class="tag {{entry.gender === '男' ? 'tag-male' : 'tag-female'}}">{{entry.gender}}</text>
      <text class="tag tag-age">{{entry.age}}岁</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="card-title">📋 基本信息</view>
    <view class="info-row">
      <text class="info-label">姓名</text>
      <text class="info-value">{{entry.name}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">性别</text>
      <text class="info-value">{{entry.gender}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">年龄</text>
      <text class="info-value">{{entry.age}}岁（{{ageGroup}}）</text>
    </view>
    <view class="info-row">
      <text class="info-label">手机号</text>
      <text class="info-value">{{entry.phone}}</text>
    </view>
  </view>

  <!-- 兴趣爱好 -->
  <view class="card" wx:if="{{entry.hobby}}">
    <view class="card-title">🎯 兴趣爱好</view>
    <view class="hobby-tags">
      <text class="hobby-tag" wx:for="{{entry.hobby.split(',')}}" wx:key="*this" wx:for-item="h">
        {{h.trim()}}
      </text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="card" wx:if="{{entry.remark}}">
    <view class="card-title">💬 备注</view>
    <text class="remark-text">{{entry.remark}}</text>
  </view>

  <!-- 时间信息 -->
  <view class="card">
    <view class="card-title">🕐 时间记录</view>
    <view class="info-row">
      <text class="info-label">登记时间</text>
      <text class="info-value">{{entry.createdAt}}</text>
    </view>
    <view class="info-row" wx:if="{{entry.updatedAt !== entry.createdAt}}">
      <text class="info-label">最后修改</text>
      <text class="info-value">{{entry.updatedAt}}</text>
    </view>
  </view>
</view>

<view wx:else class="empty">加载中...</view>