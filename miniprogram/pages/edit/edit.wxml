<view class="container">
  <view class="card">
    <view class="card-title">✏️ 编辑记录</view>

    <view class="form-group">
      <text class="form-label">年龄 *</text>
      <input class="form-input" type="number" placeholder="请输入年龄" value="{{form.age}}" bindinput="onAgeInput" />
    </view>

    <view class="form-group">
      <text class="form-label">性别 *</text>
      <radio-group class="gender-group" bindchange="onGenderChange">
        <label class="gender-item {{form.gender === '男' ? 'active' : ''}}">
          <radio value="男" checked="{{form.gender === '男'}}" color="#4f6ef7" />
          <text>男</text>
        </label>
        <label class="gender-item {{form.gender === '女' ? 'active' : ''}}">
          <radio value="女" checked="{{form.gender === '女'}}" color="#4f6ef7" />
          <text>女</text>
        </label>
      </radio-group>
    </view>

    <view class="form-group">
      <text class="form-label">手机号 *</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入11位手机号" value="{{form.phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-group">
      <text class="form-label">爱好</text>
      <input class="form-input" type="text" placeholder="如：篮球, 阅读（逗号分隔）" value="{{form.hobby}}" bindinput="onHobbyInput" />
    </view>

    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-input remark-input" placeholder="选填" value="{{form.remark}}" bindinput="onRemarkInput" />
    </view>

    <button class="btn btn-primary" bindtap="onSubmit" loading="{{submitting}}">保存修改</button>
  </view>
</view>
