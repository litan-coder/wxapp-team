.login-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #4f6ef7 0%, #6b85f9 100%);
}

.login-box {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.login-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.login-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.login-subtitle {
  display: block;
  font-size: 26rpx;
  color: #888888;
}

/* 登录类型切换 Tab */
.login-tabs {
  display: flex;
  margin-bottom: 40rpx;
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 6rpx;
}

.login-tab {
  flex: 1;
  padding: 18rpx 0;
  text-align: center;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #888888;
  transition: all 0.2s;
}

.login-tab.active {
  background: #ffffff;
  color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.login-form {
  margin-bottom: 32rpx;
}

.login-form .form-group {
  margin-bottom: 32rpx;
}

.login-form .form-input {
  height: 96rpx;
  font-size: 32rpx;
  text-align: center;
}

.login-form .password-input {
  text-align: center;
  letter-spacing: 8rpx;
}

.login-btn {
  height: 96rpx;
  font-size: 32rpx;
  margin-top: 16rpx;
}

.login-footer {
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #aaaaaa;
}