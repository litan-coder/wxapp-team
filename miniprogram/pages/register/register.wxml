<view class="container" bindtouchstart="onSwipeStart" bindtouchmove="onSwipeMove" bindtouchend="onSwipeEnd">
  <!-- 顶部：用户名 + 退出 -->
  <view class="header">
    <view class="header-left">
      <text class="header-title">团队登记</text>
      <text class="header-user">👤 {{name}}</text>
    </view>
    <button class="logout-btn" bindtap="onLogout">退出</button>
  </view>

  <!-- 统计面板 -->
  <stats-panel total="{{total}}" male="{{maleCount}}" female="{{femaleCount}}" />

  <!-- 登记表单 -->
  <view class="card">
    <view class="card-title">📝 信息登记</view>

    <view class="form-group">
      <text class="form-label">年龄 *</text>
      <input class="form-input" type="number" placeholder="请输入年龄" value="{{form.age}}" bindinput="onAgeInput" />
    </view>

    <view class="form-group">
      <text class="form-label">性别 *</text>
      <radio-group class="gender-group" bindchange="onGenderChange">
        <label class="gender-item {{form.gender === '男' ? 'active' : ''}}">
          <radio value="男" checked="{{form.gender === '男'}}" color="#4f6ef7" />
          <text>男</text>
        </label>
        <label class="gender-item {{form.gender === '女' ? 'active' : ''}}">
          <radio value="女" checked="{{form.gender === '女'}}" color="#4f6ef7" />
          <text>女</text>
        </label>
      </radio-group>
    </view>

    <view class="form-group">
      <text class="form-label">手机号 *</text>
      <input class="form-input" type="text" maxlength="11" placeholder="请输入11位手机号" value="{{form.phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-group">
      <text class="form-label">爱好</text>
      <input class="form-input" type="text" placeholder="如：篮球, 阅读（逗号分隔）" value="{{form.hobby}}" bindinput="onHobbyInput" />
    </view>

    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-input remark-input" placeholder="选填" value="{{form.remark}}" bindinput="onRemarkInput" />
    </view>

    <button class="btn btn-primary" bindtap="onSubmit" loading="{{submitting}}">提交登记</button>
  </view>

  <!-- 我的记录列表 -->
  <view class="card">
    <view class="card-title">📄 我的登记记录</view>

    <block wx:if="{{entries.length > 0}}">
      <entry-item
        wx:for="{{entries}}"
        wx:key="id"
        entry="{{item}}"
        bind:edit="onEdit"
        bind:delete="onDelete"
      />
    </block>

    <view wx:else class="empty">暂无登记记录</view>
  </view>
</view>
